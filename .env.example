# ===========================================
# Supabase設定
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# JWT設定
# ===========================================
JWT_SECRET=your-jwt-secret

# ===========================================
# アプリケーション設定
# ===========================================
APP_ENV=production
DEBUG=false

# ===========================================
# CORS設定
# ===========================================
# 複数のオリジンはカンマ区切りで指定
# 例: https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# ===========================================
# 外部サービス連携（任意・未設定時はサンプルデータ表示）
# ===========================================
# SmartHR連携（部署別 人件費・時間外）
SMARTHR_SUBDOMAIN=
SMARTHR_ACCESS_TOKEN=

# Slack連携（新規投稿・昨日の投稿）
SLACK_BOT_TOKEN=

# Googleアナリティクス(GA4)連携（EC Web分析）
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=

# 承認ワークフロー: メール通知（Resend、未設定時はログのみのサンプルモード）
RESEND_API_KEY=
RESEND_FROM_ADDRESS=KPI管理システム <noreply@gyo-za.co.jp>
# 承認画面への直リンク生成に使うフロントエンドURL
APP_BASE_URL=https://kpidash-frontend.vercel.app
